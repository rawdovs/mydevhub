# MyDevHub local muhit o'zgaruvchilari

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# Firestore REST
FIREBASE_API_KEY=your_firebase_web_api_key_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here

# Telegram Bot Token (ixtiyoriy)
BOT_TOKEN=your_telegram_bot_token_here
WEBHOOK_URL=https://your-domain.uz
TELEGRAM_WEBHOOK_SECRET=replace_with_long_random_secret
BOT_POLLING=false
ADMIN_TELEGRAM_IDS=123456789

# Anthropic API Key (ixtiyoriy)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
